---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import { SITE } from '../../consts';

const posts = (await getCollection('posts')).filter((p) => !p.data.draft);

// собираем { тег: количество }
const counts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) {
    counts.set(t, (counts.get(t) ?? 0) + 1);
  }
}
// сортируем по частоте, потом по алфавиту
const tags = [...counts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<Base title={`tags — ${SITE.title}`} description="Все теги.">
  <a class="back" href="/">← {SITE.handle}</a>

  <h2 class="eyebrow">tags</h2>

  {tags.length === 0 ? (
    <p class="prose">Пока ни одного тега — появятся, как только будут посты.</p>
  ) : (
    <ul class="taglist">
      {tags.map(([tag, n]) => (
        <li>
          <a class="tagchip" href={`/tags/${tag}/`}>#{tag}</a>
          <span class="tagcount">{n}</span>
        </li>
      ))}
    </ul>
  )}

  <Footer />
</Base>
