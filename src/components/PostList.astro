---
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10); // YYYY-MM-DD, моноширинно смотрится ровно
---

<section class="rise">
  <h2 class="eyebrow">writing</h2>
  <ul class="log">
    {posts.map((post) => (
      <li class="entry">
        <a href={`/posts/${post.id}/`}>
          <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
          <span class="title">{post.data.title}</span>
          {post.data.tags.length > 0 && (
            <span class="tags">{post.data.tags.map((t) => `#${t}`).join('  ')}</span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>
