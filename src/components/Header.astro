---
import { SITE, SOCIALS } from '../consts';

// текущий год для статус-строки — обновляется на билде
const year = new Date().getFullYear();
---

<header class="masthead rise">
  <h1 class="name">{SITE.handle.slice(0, -3)}<span class="dot">{SITE.handle.slice(-3)}</span></h1>
  <div class="status">
    <span class="pulse">online</span>
    <span class="sep">/</span>
    <span>{SITE.timezone}</span>
    <span class="sep">/</span>
    <span>backend · python · fastapi</span>
  </div>

  <p class="bio" set:html={SITE.description}></p>

  <nav class="socials" aria-label="Контакты">
    {SOCIALS.map((s) => (
      <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} title={s.label}>
        {s.type === 'telegram' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71l-4.14-3.05-1.99 1.93c-.23.23-.42.42-.83.42z"/>
          </svg>
        )}
        {s.type === 'github' && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.92 1.23 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0024 12.5C24 5.87 18.63.5 12 .5z"/>
          </svg>
        )}
        {s.type === 'email' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
          </svg>
        )}
      </a>
    ))}
  </nav>
</header>
